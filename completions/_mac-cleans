#compdef mac-cleans Mac-Clean

_mac_cleans() {
    local -a options categories

    options=(
        '--dry-run[Dry run - show what would be deleted]'
        '--force[Skip all confirmations]'
        '--yes[Skip confirmations (except Xcode)]'
        '--interactive[Interactive mode]'
        '--json[JSON output]'
        '--version[Show version]'
        '--help[Show help]'
    )

    categories=(
        '--skip-snapshots[Skip Time Machine snapshots]'
        '--skip-homebrew[Skip Homebrew cache]'
        '--skip-spotify[Skip Spotify cache]'
        '--skip-claude[Skip Claude cache]'
        '--skip-xcode[Skip Xcode Derived Data]'
        '--skip-browsers[Skip browser cache (Chrome, Firefox, Edge)]'
        '--skip-npm[Skip npm/Yarn cache]'
        '--skip-pip[Skip Python pip cache]'
        '--skip-trash[Skip trash emptying]'
        '--skip-dsstore[Skip .DS_Store files]'
        '--skip-docker[Skip Docker cache]'
        '--skip-simulator[Skip iOS Simulator data]'
        '--skip-mail[Skip Mail cache]'
        '--skip-siri-tts[Skip Siri TTS cache]'
        '--skip-icloud-mail[Skip iCloud Mail cache]'
        '--skip-photos-library[Skip Photos Library cache]'
        '--skip-icloud-drive[Skip iCloud Drive offline files]'
        '--skip-quicklook[Skip QuickLook thumbnails]'
        '--skip-diagnostics[Skip Diagnostic reports]'
        '--skip-ios-backups[Skip iOS device backups]'
        '--skip-ios-updates[Skip iOS update files]'
        '--skip-cocoapods[Skip CocoaPods cache]'
        '--skip-gradle[Skip Gradle cache]'
        '--skip-go[Skip Go module cache]'
        '--skip-bun[Skip Bun cache]'
        '--skip-pnpm[Skip pnpm store]'
    )

    _arguments -s -S "$options[@]" "$categories[@]"
}

_mac_cleans "$@"
