#compdef mac-cleans Mac-Clean

_mac_cleans() {
    local -a options categories

    options=(
        '--dry-run[Dry run - show what would be deleted]'
        '--force[Skip all confirmations]'
        '--yes[Skip confirmations (except Xcode)]'
        '--interactive[Interactive mode]'
        '--json[JSON output]'
        '--version[Show version]'
        '--help[Show help]'
    )

    categories=(
        '--skip-xcode[Skip Xcode Derived Data]'
        '--skip-homebrew[Skip Homebrew cache]'
        '--skip-docker[Skip Docker cache]'
        '--skip-npm[Skip npm/Yarn cache]'
        '--skip-pip[Skip Python pip cache]'
        '--skip-chrome[Skip Chrome cache]'
        '--skip-firefox[Skip Firefox cache]'
        '--skip-edge[Skip Edge cache]'
        '--skip-spotify[Skip Spotify cache]'
        '--skip-mail[Skip Mail cache]'
        '--skip-icloud[Skip iCloud cache]'
        '--skip-trash[Skip trash emptying]'
        '--skip-gradle[Skip Gradle cache]'
        '--skip-bun[Skip Bun cache]'
        '--skip-pnpm[Skip pnpm store]'
        '--skip-photos[Skip Photos cache]'
        '--skip-quicklook[Skip QuickLook cache]'
        '--skip-diagnostics[Skip Diagnostic reports]'
    )

    _arguments -s -S "$options[@]" "$categories[@]"
}

_mac_cleans "$@"
